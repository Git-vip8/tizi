{
  "inbounds": [
    {
      "type": "hysteria2",
      "tag": "hy2-in",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "name": "user1",
          "password": "Tz123456"
        }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "/etc/sing-box/certs/cert.pem",
        "key_path": "/etc/sing-box/certs/private.key"
      },
      "masquerade": {
        "type": "proxy",
        "url": "https://www.google.com",
        "rewrite_host": true
      },
      "ignore_client_bandwidth": false
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "domain_suffix": [
          ".local",
          ".lan"
        ],
        "outbound": "direct"
      },
      {
        "domain": [
          "ntp.org",
          "time.apple.com"
        ],
        "outbound": "direct"
      }
    ]
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-remote",
        "address": "https://1.1.1.1/dns-query",
        "strategy": "ipv4_only"
      },
      {
        "tag": "dns-local",
        "address": "https://223.5.5.5/dns-query",
        "strategy": "ipv4_only"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "cn"
        ],
        "server": "dns-local"
      }
    ]
  }
}